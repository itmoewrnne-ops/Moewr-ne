# Tusaale kaliya - Ma jiraan xog rasmiga ah!
# Copy this file to .env and fill in YOUR real values

# Database connection
DATABASE_URL="postgresql://your_username:your_password@localhost:5432/your_database?schema=public"

# JWT Secret - ugu yaraan 32 characters
JWT_SECRET="your_secret_key_min_32_characters_here"

# Optional
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"